---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Past Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Past Projects</div>
  </div>

  <HorizontalCard
    title="MonoWorld RP"
    img="/monoworld_thumb.webp"
    subtitle="UEFN, Monoford Studios, 2026"
    desc="Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua."
    url="https://www.fortnite.com/@monoford/8651-5006-2690"
  />

  <div class="divider my-0"></div><!-- 2025 -->
  <HorizontalCard
    title="Repeat Offender"
    img="/repeatoffender_thumb.webp"
    subtitle="s&box, Ninety Four, 2025"
    desc="First place S&box Game Jam #1 winner. A top down stealth puzzle game with clones and time manipulation. I used the gradient atlas technique to achieve fast and cohesive results."
    url="https://itch.io/jam/sbox-jam-1/rate/3678000"
    badge="1st Place"
  />
  <HorizontalCard
    title="Flood Survival"
    img="/flood_thumb.webp"
