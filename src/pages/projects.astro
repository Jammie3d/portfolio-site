    badge="2nd Place"
  />
  <HorizontalCard
    title="Play for Skateistan"
    img="/skateistan_thumb.webp"
    subtitle="UE4/Session Skate Sim, Skateistan, 2023"
    desc="A community collaboration for the Play for Skateistan charity campaign, I ported two of the virtual skateparks from SkaterXL (Unity) into Session (UE4)."
    url="https://playforskateistan.com/"
  />
  <div class="divider my-0"></div><!-- 2022 -->
  <HorizontalCard
    title="Cold Open"
    img="/coldopen_thumb.webp"
    subtitle="s&box, Ape Tavern, 2022"
    desc="Our entry for Gvarados's Halloween Horror Super Jam, we created a sci-fi horror game where you are stranded on a ship with a shapeshifting alien. I designed and created the ship environment alongside some props and materials."
    url="https://www.gvar.net/contest"
    badge="1st Place"
  />
  <HorizontalCard
    title="Session Modding Template & Wiki"
    img="/sessiontemplate_thumb.webp"
    subtitle="UE4/Session Skate Sim, 2022"
    desc="Provided a project template and a wiki with tutorials to help grow the Session modding community."
    url="https://github.com/Jammie3d/Session_Template"
  />
  <HorizontalCard
    title="Bristol Amphitheatre"
    img="/lloyds_thumb.webp"
