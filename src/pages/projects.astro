---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title = "Past Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold mb-5">Past Projects</div>
  </div>

  <HorizontalCard
    title="Mono World RP"
    img="/monoworld-thumb.webp"
    subtitle="UEFN, Monoford Studios, 2026"
    desc="A roleplaying game created in UEFN. I helped design and decorate the map, created a custom landscape shader, produced stylized assets and optimized everything to stay within limited memory constraints."
    url="https://www.fortnite.com/@monoford/8651-5006-2690"
  />

  <div class="divider my-0"></div><!-- 2025 -->
  <HorizontalCard
    title="Repeat Offender"
    img="/repeatoffender-thumb.webp"
    subtitle="s&box, Ninety Four, 2025"
    desc="First place winner of Trundler's S&box Game Jam #1. A top down stealth puzzle game with clones and time manipulation. As the sole artist I used the gradient atlas technique to achieve fast and cohesive results."
    url="https://itch.io/jam/sbox-jam-1/rate/3678000"
    badge="1st Place"
  />
  <HorizontalCard
    title="Flood Survival"
    img="/flood-thumb.webp"
    subtitle="s&box, Ape Tavern, 2025"
    desc="Our take on the classic Garry's Mod gamemode Flood, a game where you have to build a raft and sink your opponents. I created one of the maps as well as several materials, decals, VFX and props."
    url="https://sbox.game/apetavern/deluge"
  />
  <HorizontalCard
    title="Clean Up!"
    img="/cleanup-thumb.webp"
    subtitle="s&box, Ape Tavern, 2025"
    desc="A cleaning simulator game with pressure washing, rubbish collection and furniture moving. I created the map, VFX, some materials, decals & props as well as the branding."
    url="/blog/clean-up"
  />
  <HorizontalCard
    title="Winter Fortress Environment"
    img="/winterfortress-thumb.webp"
    subtitle="s&box, 2025"
    desc="My solo entry for the official s&box Tech Jam. I recreated a scene from the movie Inception and allowed players to immerse themselves in the ambience or explore and take screenshots."
    url="/blog/winter-fortress"
  />

  <div class="divider my-0"></div><!-- 2024 -->
  <HorizontalCard
    title="Micro Mayhem"
    img="/micromayhem-thumb.webp"
    subtitle="s&box, Ape Tavern, 2024"
    desc="First place s&box Game Jam II winner. A multiplayer 3D platformer set at a miniature scale. I created realistic assets, took early blockouts to finalized environments, produced stylized VFX."
    url="https://www.artstation.com/artwork/y4DoAR"
    badge="1st Place"
  />
  <HorizontalCard
    title="Turf Wars: Cops & Robbers"
    img="/turfwars-thumb.webp"
    subtitle="UEFN, Monoford Studios, 2024"
    desc="A multiplayer zone capture gamemode made in UEFN. I designed and decorated the map, created some custom stylized assets and helped capture screenshots and video footage for marketing."
    url="https://www.fortnite.com/@monoford/9015-3948-6092"
  />
  <HorizontalCard
    title="The Adventurer's Museum"
    img="/adventurersmuseum-thumb.webp"
    subtitle="UE5, DiNusty Empire, 2024"
    desc="A group project with the DiNusty Empire community. I worked on trimsheets with the environment team and designed the posters and other graphics for each exhibit."
    url="https://www.artstation.com/artwork/m8rn9E"
  />
  <HorizontalCard
    title="GRUG"
    img="/grug-thumb.webp"
    subtitle="s&box, Ape Tavern, 2024"
    desc="Our entry for the first official s&box Game Jam, a caveman themed survival game with combat, resource gathering, crafting and building. I worked on the weapon and tool models, building assets, map, materials, and VFX."
    url="/blog/grug"
    badge="5th Place"
  />
  <HorizontalCard
    title="Funicular Platform"
    img="/funicular-thumb.webp"
    subtitle="UE5, 2024"
    desc="A UE5 environment project leveraging Nanite and Lumen, my take on the funicular elevator trope but in a contemporary setting. Mentored by Jeremy Estrellado (Ubisoft&nbsp;Massive). "
    url="https://www.artstation.com/artwork/ob1YXO"
  />

  <div class="divider my-0"></div><!-- 2023 -->
  <HorizontalCard
    title="What Lurks Below"
    img="/whatlurksbelow-thumb.webp"
    subtitle="s&box, Ape Tavern, 2023"
    desc="Our entry for the Mighty Brick Halloween Game Jam. A survival horror game with randomly generated levels, also one of the first games made in s&box's scene system. I created the modular environment pieces, materials, VFX and some props."
    url="/blog/what-lurks-below"
    badge="3rd Place"
  />
  <HorizontalCard
    title="Grubs"
    img="/grubs-thumb.webp"
    subtitle="s&box, Ape Tavern, 2023"
    desc="A 2.5D turn based artillery game with destructible terrain. I created tileable materials, stylized VFX and 3D backgrounds."
    url="https://sbox.game/apetavern/grubs"
  />
  <HorizontalCard
    title="Parkour Painters"
    img="/parkourpainters-thumb.webp"
    subtitle="s&box, Ape Tavern, 2023"
    desc="Our entry for the Three Thieves Game Jam, A competitive multiplayer game where four teams traverse and fight over graffiti zones. I created the modular environment kits, materials, VFX and one of the two playable maps."
    url="https://www.youtube.com/watch?v=gjLvK24ssx8"
    badge="2nd Place"
  />
  <HorizontalCard
    title="Play for Skateistan"
    img="/skateistan-thumb.webp"
    subtitle="UE4/Session Skate Sim, Skateistan, 2023"
    desc="A community collaboration for the Play for Skateistan charity campaign, I ported two of the virtual skateparks from SkaterXL (Unity) into Session (UE4)."
    url="https://playforskateistan.com/"
  />

  <div class="divider my-0"></div><!-- 2022 -->
  <HorizontalCard
    title="Cold Open"
    img="/coldopen-thumb.webp"
    subtitle="s&box, Ape Tavern, 2022"
    desc="Our entry for Gvarados's Halloween Horror Super Jam, we created a sci-fi horror game where you are stranded on a ship with a shapeshifting alien. I designed and created the ship environment alongside some props and materials."
    url="/blog/cold-open"
    badge="1st Place"
  />
  <HorizontalCard
    title="Session Modding Template & Wiki"
    img="/sessiontemplate-thumb.webp"
    subtitle="UE4/Session Skate Sim, 2022"
    desc="Provided a project template and a wiki with tutorials to help grow the Session modding community."
    url="https://github.com/Jammie3d/Session_Template"
  />
  <HorizontalCard
    title="Bristol Amphitheatre"
    img="/lloyds-thumb.webp"
    subtitle="UE4/Session Skate Sim, 2022"
    desc="Mod map for Session: Skate Sim. A recreation of the iconic Lloyds Amphitheatre skate spot in Bristol, UK."
    url="/blog/bristol-amphitheatre"
  />
  <HorizontalCard
    title="An Honourable Duel"
    img="/ggj22-thumb.webp"
    subtitle="Three.js, Bristol Games Hub, 2022"
    desc="Our Global Game Jam 2022 entry, I created the characters and weapon models in a low poly pixel art style and implemented the Mixamo animations."
    url="https://v3.globalgamejam.org/2022/games/honourable-dual-1"
  />

  <div class="divider my-0"></div><!-- 2020 -->
  <HorizontalCard
    title="Supa Happy Deth Slide"
    img="/gmtk20-thumb.webp"
    subtitle="UE4, 2020"
    desc="GMTK Game Jam 2020 entry, a simple sliding platformer where your inputs are a limited resource."
    url="https://itch.io/jam/gmtk-2020/rate/693830"
  />

  <div class="divider my-0"></div><!-- 2019 -->
  <HorizontalCard
    title="Blokto Park"
    img="/blokto-thumb.webp"
    subtitle="UE4/Session Skate Sim, 2019"
    desc="Mod map for Session: Skate Sim. For Blocktober I designed and created a playable indoor skatepark in a month and later expanded it with an outdoor area."
    url="/blog/blokto-park"
  />
</BaseLayout>
