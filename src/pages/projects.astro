  />
  <HorizontalCard
    title="The Adventurer's Museum"
    img="/adventurersmuseum_thumb.webp"
    subtitle="UE5, DiNusty Empire, 2024"
    desc="A group project with the DiNusty Empire community. I created trimsheets for the environment team and designed posters and other graphics for each exhibit."
    url="https://www.artstation.com/artwork/m8rn9E"
  />
  <HorizontalCard
    title="GRUG"
    img="/grug_thumb.webp"
    subtitle="s&box, Ape Tavern, 2024"
    desc="Our entry for the first official s&box Game Jam, a caveman themed survival game."
    url="#"
    badge="5th Place"
  />
  <HorizontalCard
    title="Funicular Platform"
    img="/funicular_thumb.webp"
    subtitle="UE5, 2024"
    desc="An Unreal Engine 5 environment project, mentored by Jeremy Estrellado (Ubisoft&nbsp;Massive). I designed and produced the cinematic environment from start to finish."
