    title="Winter Fortress Environment"
    img="/winterfortress_thumb.webp"
    subtitle="s&box, 2025"
    desc="s&box Tech Jam"
    url="#"
  />

  <div class="divider my-0"></div><!-- 2024 -->
  <HorizontalCard
    title="Micro Mayhem"
    img="/micromayhem_thumb.webp"
    subtitle="s&box, Ape Tavern, 2024"
    desc="First place s&box Game Jam II winner. A multiplayer 3D platformer set at a miniature scale. I created realistic assets, took early blockouts to finalized environments, produced stylized VFX."
    url="https://sbox.game/apetavern/micromayhem"
    badge="1st Place"
  />
  <HorizontalCard
    title="Turf Wars: Cops & Robbers (UEFN)"
