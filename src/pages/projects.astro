    url="#"
    badge="3rd Place"
  />
  <HorizontalCard
    title="Grubs"
    img="/grubs_thumb.webp"
    subtitle="s&box, Ape Tavern, 2023"
    desc="A 2.5D turn based artillery shooter with destructible terrain. I created tileable materials, stylized VFX and 3D backgrounds."
    url="https://sbox.game/apetavern/grubs"
  />
  <HorizontalCard
    title="Parkour Painters"
